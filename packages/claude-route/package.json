{
  "name": "@wechat2all/claude-route",
  "version": "0.1.0",
  "private": true,
  "description": "Independent Claude Agent SDK route for wechat2all",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist/",
    "weconnect.route.json"
  ],
  "weconnect": {
    "routeManifest": "./weconnect.route.json",
    "routeEntrypoint": "."
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.ts",
    "check": "pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.210",
    "@wechat2all/route-sdk": "workspace:*",
    "@wechat2all/runtime": "workspace:*",
    "zod": "^4.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
