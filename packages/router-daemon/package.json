{
  "name": "@wechat2all/router-daemon",
  "version": "0.1.0",
  "private": true,
  "description": "Local router daemon for the wechat2all desktop app",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "start": "node dist/index.mjs",
    "test": "node --import tsx --test tests/*.test.ts",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "check": "pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "@wechat2all/claude-route": "workspace:*",
    "@wechat2all/codex-route": "workspace:*",
    "@wechat2all/office-route": "workspace:*",
    "@wechat2all/route-sdk": "workspace:*",
    "@wechat2all/runtime": "workspace:*",
    "wechat2all": "workspace:*"
  },
  "devDependencies": {},
  "engines": {
    "node": ">=20"
  }
}
