{
  "name": "wechat2all-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Local-first WeChat gateway monorepo for bots, agents, and automations",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter wechat2all dev",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "check": "pnpm -r check",
    "echo-bot": "pnpm --filter wechat2all echo-bot",
    "runtime-bot": "pnpm --filter @wechat2all/runtime runtime-bot",
    "codex-gui-bridge": "pnpm --filter @wechat2all/codex-gui-bridge dev",
    "desktop": "pnpm --filter @wechat2all/desktop dev",
    "desktop:build": "pnpm --filter @wechat2all/desktop tauri:build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsdown": "^0.21.4",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0"
  }
}
