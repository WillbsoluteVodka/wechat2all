WECHAT2ALL_LLM_PROVIDER=openai-compatible
WECHAT2ALL_LLM_API_KEY=replace-me
WECHAT2ALL_LLM_MODEL=gpt-4.1-mini
WECHAT2ALL_LLM_BASE_URL=https://api.openai.com/v1
WECHAT2ALL_LLM_MAX_TOKENS=800
WECHAT2ALL_LLM_TIMEOUT_MS=15000
# Startup/API-key health probe timeout. The daemon runs one lightweight probe
# when it starts; POST /llm/health/check can run it again on demand.
# WECHAT2ALL_LLM_HEALTH_TIMEOUT_MS=15000

# Community Route Protocol v1 packages. Values may be npm package specifiers,
# absolute paths, relative paths, or file: URLs; separate multiple values with commas.
# WECHAT2ALL_ROUTE_PACKAGES=@alice/weconnect-route-calendar,/absolute/path/to/route/dist/index.mjs

# WeChat iLink sessions last 24 hours. WeConnect sends the session owner one
# remaining-time reminder per hour after it has received a message/context token.
# WECHAT2ALL_SESSION_DURATION_MINUTES=1440
# WECHAT2ALL_SESSION_REMINDER_INTERVAL_MINUTES=60

# Runtime action execution:
# - max attempts includes the first attempt.
# - action dedupe is opt-in; leave at 0 unless a connector provides stable dedupe keys.
WECHAT2ALL_ACTION_MAX_ATTEMPTS=2
WECHAT2ALL_ACTION_RETRY_DELAY_MS=250
WECHAT2ALL_ACTION_DEDUPE_WINDOW_MS=0

# Agent memory:
# - local: writes transcript JSONL locally and performs lightweight fallback search.
# - mem0: composes local JSONL with Mem0 long-term memory.
WECHAT2ALL_MEMORY_PROVIDER=local
# WECHAT2ALL_MEMORY_PROVIDER=mem0
# WECHAT2ALL_MEM0_API_KEY=replace-me
# WECHAT2ALL_MEM0_BASE_URL=https://api.mem0.ai
# WECHAT2ALL_MEM0_TIMEOUT_MS=15000
# WECHAT2ALL_MEMORY_LOCAL_MAX_SEARCH_ROWS=2000

# Claude route (independent Claude Agent SDK package):
# Enter from the main router with `/cd claude`.
# Third-party integrations should use an Anthropic API key. Reusing a local
# Claude Code account is disabled unless WECHAT2ALL_CLAUDE_ALLOW_CLI_AUTH=1.
# ANTHROPIC_API_KEY=replace-me
# WECHAT2ALL_CLAUDE_WORKDIR=/absolute/path/to/obsidian-vault-or-workspace
# WECHAT2ALL_CLAUDE_MODEL=claude-sonnet-4-5
# WECHAT2ALL_CLAUDE_LANGUAGE=zh
# WECHAT2ALL_CLAUDE_SESSION_WINDOW_MINUTES=15
# WECHAT2ALL_CLAUDE_MAX_MEDIA_MB=50
# WECHAT2ALL_CLAUDE_MAX_TURNS=40
# WECHAT2ALL_CLAUDE_MAX_BUDGET_USD=1
# WECHAT2ALL_CLAUDE_TIMEOUT_MS=600000
# WECHAT2ALL_CLAUDE_PROMPT_FILE=/optional/path/to/editable-prompt.md
# WECHAT2ALL_CLAUDE_EXECUTABLE=/optional/path/to/claude
# WECHAT2ALL_CLAUDE_ALLOW_CLI_AUTH=0

# Office route (independent WeConnect LLM + OfficeCLI):
# Reuses WECHAT2ALL_LLM_API_KEY, WECHAT2ALL_LLM_MODEL, and WECHAT2ALL_LLM_BASE_URL above.
# Install OfficeCLI separately, then enter with `/cd office`.
# WECHAT2ALL_OFFICECLI_EXECUTABLE=/optional/absolute/path/to/officecli
# WECHAT2ALL_OFFICE_MAX_TURNS=12
# WECHAT2ALL_OFFICE_MAX_COMMANDS_PER_TURN=12
# WECHAT2ALL_OFFICE_COMMAND_TIMEOUT_MS=120000
# WECHAT2ALL_OFFICE_MAX_MEDIA_MB=50

# Codex route:
# Codex route defaults to direct GUI delivery, with app-server observation and
# fallback. It opens the bound chat, pastes attachments/text, and presses Return.
# WECHAT2ALL_CODEX_THREAD_ID=optional-prebound-thread-id
# app-server: send via Codex app-server protocol.
# desktop-ipc: experimental internal Codex Desktop transport. Do not use as
# the default; some unloaded GUI chats do not expose an owning client.
# gui-automation (default): paste into the exact bound GUI chat and press Return;
# app-server observes the completed turn and is used only if GUI injection fails.
# WECHAT2ALL_CODEX_DELIVERY=gui-automation
# WECHAT2ALL_CODEX_DESKTOP_IPC_SOCKET=/optional/path/to/codex-ipc.sock
# WECHAT2ALL_CODEX_DESKTOP_IPC_TIMEOUT_MS=30000
# WECHAT2ALL_CODEX_DESKTOP_IPC_THREAD_OPEN_DELAY_MS=1200
# WECHAT2ALL_CODEX_APP_SERVER_SOCKET=/optional/path/to/app-server-control.sock
# WECHAT2ALL_CODEX_APP_SERVER_TIMEOUT_MS=8000
# WECHAT2ALL_CODEX_TURN_TIMEOUT_MS=180000
# Absolute ceiling even when Codex continues reporting in-progress/compaction.
# The default is 30 minutes so long Codex tasks can still return their final answer.
# WECHAT2ALL_CODEX_MAX_TURN_WAIT_MS=1800000
# Whole-route watchdog. It releases the WeChat conversation queue and attempts
# bridge recovery if any command remains stuck beyond this ceiling.
# WECHAT2ALL_CODEX_ROUTE_OPERATION_TIMEOUT_MS=2100000
# While a turn is running, WeChat receives this periodic progress update.
# WECHAT2ALL_CODEX_PROCESSING_REMINDER_MS=120000
# Extra wait when a real Codex turn is still running at the soft deadline.
# WECHAT2ALL_CODEX_IN_PROGRESS_GRACE_MS=120000
# Extra wait only when Codex is actively compacting a long chat.
# WECHAT2ALL_CODEX_COMPACTION_GRACE_MS=180000
# WECHAT2ALL_CODEX_GUI_POLL_INTERVAL_MS=1000
# GUI injection must become visible to app-server within this window or the
# whole request is retried through app-server (important while locked/asleep).
# WECHAT2ALL_CODEX_GUI_TURN_OBSERVATION_MS=10000
# WECHAT2ALL_CODEX_GUI_THREAD_OPEN_DELAY_MS=900
# WECHAT2ALL_CODEX_GUI_NEW_CHAT_DISCOVERY_MS=15000
# WECHAT2ALL_CODEX_LIST_LIMIT=20

# If your terminal cannot reach api.openai.com directly, point Node/curl at
# your local proxy. Replace the port with your proxy app's mixed/http port.
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
# NO_PROXY=localhost,127.0.0.1
