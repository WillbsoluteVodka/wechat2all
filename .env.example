WECHAT2ALL_LLM_PROVIDER=openai-compatible
WECHAT2ALL_LLM_API_KEY=replace-me
WECHAT2ALL_LLM_MODEL=gpt-4.1-mini
WECHAT2ALL_LLM_BASE_URL=https://api.openai.com/v1
WECHAT2ALL_LLM_MAX_TOKENS=800
WECHAT2ALL_LLM_TIMEOUT_MS=15000

# WeChat iLink sessions last 24 hours. WeConnect sends the session owner one
# remaining-time reminder per hour after it has received a message/context token.
# WECHAT2ALL_SESSION_DURATION_MINUTES=1440
# WECHAT2ALL_SESSION_REMINDER_INTERVAL_MINUTES=60

# Runtime action execution:
# - max attempts includes the first attempt.
# - action dedupe is opt-in; leave at 0 unless a connector provides stable dedupe keys.
WECHAT2ALL_ACTION_MAX_ATTEMPTS=2
WECHAT2ALL_ACTION_RETRY_DELAY_MS=250
WECHAT2ALL_ACTION_DEDUPE_WINDOW_MS=0

# Agent memory:
# - local: writes transcript JSONL locally and performs lightweight fallback search.
# - mem0: composes local JSONL with Mem0 long-term memory.
WECHAT2ALL_MEMORY_PROVIDER=local
# WECHAT2ALL_MEMORY_PROVIDER=mem0
# WECHAT2ALL_MEM0_API_KEY=replace-me
# WECHAT2ALL_MEM0_BASE_URL=https://api.mem0.ai
# WECHAT2ALL_MEM0_TIMEOUT_MS=15000
# WECHAT2ALL_MEMORY_LOCAL_MAX_SEARCH_ROWS=2000

# Codex route:
# Stable bridge using GUI automation for text delivery and Codex app-server
# for discovery, image inputs, and result collection.
# WECHAT2ALL_CODEX_THREAD_ID=optional-prebound-thread-id
# app-server: send via Codex app-server protocol.
# desktop-ipc: experimental internal Codex Desktop transport. Do not use as
# the default; some unloaded GUI chats do not expose an owning client.
# gui-automation: open codex://threads/<bound-thread-id>, paste into that Codex GUI
# chat, press Enter, then poll the same bound thread for the final answer.
# WECHAT2ALL_CODEX_DELIVERY=gui-automation
# WECHAT2ALL_CODEX_DESKTOP_IPC_SOCKET=/optional/path/to/codex-ipc.sock
# WECHAT2ALL_CODEX_DESKTOP_IPC_TIMEOUT_MS=30000
# WECHAT2ALL_CODEX_DESKTOP_IPC_THREAD_OPEN_DELAY_MS=1200
# WECHAT2ALL_CODEX_APP_SERVER_SOCKET=/optional/path/to/app-server-control.sock
# WECHAT2ALL_CODEX_APP_SERVER_TIMEOUT_MS=8000
# WECHAT2ALL_CODEX_TURN_TIMEOUT_MS=180000
# Once a Codex turn is observed, the bridge keeps listening until it really
# finishes. While it is running, WeChat receives this periodic progress update.
# WECHAT2ALL_CODEX_PROCESSING_REMINDER_MS=120000
# Extra wait when a real Codex turn is still running at the soft deadline.
# WECHAT2ALL_CODEX_IN_PROGRESS_GRACE_MS=120000
# Extra wait only when Codex is actively compacting a long chat.
# WECHAT2ALL_CODEX_COMPACTION_GRACE_MS=180000
# WECHAT2ALL_CODEX_GUI_POLL_INTERVAL_MS=1000
# WECHAT2ALL_CODEX_GUI_THREAD_OPEN_DELAY_MS=900
# WECHAT2ALL_CODEX_LIST_LIMIT=20

# If your terminal cannot reach api.openai.com directly, point Node/curl at
# your local proxy. Replace the port with your proxy app's mixed/http port.
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
# NO_PROXY=localhost,127.0.0.1
